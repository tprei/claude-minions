# Copy to .env.local (gitignored) and fill in your values.
# The engine launcher (bin/engine.sh) sources this on startup.

# Required: bearer token for the HTTP API and PWA → engine connections
MINIONS_TOKEN=changeme

# Bind address + workspace root
MINIONS_PORT=8787
MINIONS_HOST=127.0.0.1
MINIONS_WORKSPACE=./.dev-workspace

# Provider: claude-code (real) or mock (for dev)
MINIONS_PROVIDER=claude-code

# Logging: debug | info | warn | error
MINIONS_LOG_LEVEL=info

# CORS allowlist for the PWA (comma-separated)
MINIONS_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Bound repos as JSON
MINIONS_REPOS='[{"id":"self","label":"claude-minions","remote":"https://github.com/tprei/claude-minions.git","defaultBranch":"main"}]'

# GitHub App credentials (preferred). Falls back to gh CLI auth if these are unset.
# Client ID (newer) or App ID (legacy numeric) — both work as JWT iss
MINIONS_GH_APP_ID=
# Either an absolute path to the .pem, or the PEM contents pasted inline
MINIONS_GH_APP_PRIVATE_KEY=
# Numeric installation id from /settings/installations/<id>
MINIONS_GH_APP_INSTALLATION_ID=

# Optional: web-push (only needed if you want push notifications)
# MINIONS_VAPID_PUBLIC=
# MINIONS_VAPID_PRIVATE=
# MINIONS_VAPID_SUBJECT=mailto:ops@example.com
