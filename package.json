{
  "name": "claude-minions",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent coding orchestrator — engine + PWA",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=4 run build",
    "dev:engine": "pnpm --filter @minions/engine run dev",
    "dev:web": "pnpm --filter @minions/web run dev",
    "dev:sidecar": "pnpm --filter @minions/sidecar run dev",
    "dev": "concurrently -n engine,web,sidecar -c blue,green,magenta \"pnpm dev:engine\" \"pnpm dev:web\" \"pnpm dev:sidecar\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo packages/web/dist"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
