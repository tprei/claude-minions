{
  "name": "@minions/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "minions-engine": "./dist/cli.js",
    "minions-supervise": "./dist/bin/supervise.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "supervise": "node dist/bin/supervise.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "rm -rf dist",
    "test": "find src -type f -name '*.test.ts' -print0 | xargs -0 node --import tsx --test --test-reporter=spec"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.3",
    "@minions/shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "fastify": "^5.1.0",
    "nanoid": "^5.0.9",
    "p-limit": "^6.1.0",
    "p-queue": "^8.0.1",
    "simple-git": "^3.27.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
